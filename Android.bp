android_app {
    name: "GetResumedPkgTest",
    srcs: ["src/**/*.java"],
    resource_dirs: ["res"],
    manifest: "AndroidManifest.xml",
    platform_apis: true,
    certificate: "platform",
    privileged: true,
    static_libs: [
        "androidx.core_core",
        "androidx.appcompat_appcompat",
    ],
    optimize: {
        enabled: false,
    },
}
